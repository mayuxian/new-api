{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug new-api",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}",
      "env": {
        "CGO_ENABLED": "0",
        "GIN_MODE": "debug",
        "DEBUG": "true",
        "PORT": "3002",
        "SQL_DSN": "postgresql://root:123456@localhost:5432/new-api",
        "REDIS_CONN_STRING": "redis://localhost:6379",
        "BATCH_UPDATE_ENABLED": "true",
        "TZ": "Asia/Shanghai"
      },
      "args": [],
      "preLaunchTask": "ensure-dev-services"
    },
    {
      "name": "Debug Web Default",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "http://localhost:3001",
      "webRoot": "${workspaceFolder}/web/default",
      "preLaunchTask": "start-web-default"
    }
  ],
  "compounds": [
    {
      "name": "Debug Full Stack",
      "configurations": ["Debug new-api", "Debug Web Default"]
    }
  ]
}