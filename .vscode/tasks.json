{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "ensure-dev-services",
      "type": "shell",
      "command": "docker compose -f docker-compose.dev.yml up -d redis postgres",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "start-web-default",
      "type": "shell",
      "command": "bun run dev",
      "isBackground": true,
      "options": {
        "cwd": "${workspaceFolder}/web/default"
      },
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Rsbuild v",
          "endsPattern": "Local:.*"
        }
      }
    }
  ]
}